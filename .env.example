# Server-side PostgreSQL connection. For Supabase, use the pooled connection string from Project Settings > Database.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require"

# Frontend-safe Supabase configuration. These values are public by design and may be used by browser clients.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"

# Groq API key for AI-powered solution generation using Llama Scout 4.
GROQ_API_KEY="gsk_YOUR_GROQ_API_KEY"
